{
  "name": "mission-icarus",
  "author": "Gitarackur--Peter",
  "private": true,
  "version": "0.0.86",
  "type": "module",
  "scripts": {
    "prepare:python:scripts": "cd assets/scripts/python && pipenv install --dev && pipenv run prepare",
    "pipenv-install": "cd assets/scripts/python && pipenv run prepare",
    "dev": "vite",
    "prestart": "tsc && vite build",
    "start": "electron --trace-warnings .",
    "build": "tsc && vite build && electron-builder",
    "build:linux": "tsc && vite build && electron-builder --linux",
    "build:windows": "tsc && vite build && electron-builder --win",
    "build:windows1": "tsc && vite build && electron-builder --win",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "migrate": "ts-node src/database/cli.ts migrate",
    "rollback": "ts-node src/database/cli.ts rollback [version]",
    "migration:status": "ts-node src/database/cli.ts status",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/papaparse": "^5.3.16",
    "better-sqlite3": "^12.2.0",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "jstat": "^1.9.6",
    "lodash": "^4.17.21",
    "lucide-react": "^0.539.0",
    "node-fetch": "^3.3.2",
    "papaparse": "^5.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.1.2",
    "simple-statistics": "^7.8.9",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^2.1.0",
    "tailwindcss": "^4.1.11",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@electron/packager": "^18.4.2",
    "@types/d3": "^7.4.3",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.2.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "react-is": "^19.1.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=20.0.0"
  }
}
